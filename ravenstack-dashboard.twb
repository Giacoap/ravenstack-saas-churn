    <worksheet name='WS_RiskTable'>
      <table>
        <view>
          <datasources>
            <datasource caption='churn_risk_scores' name='federated.1q1aqzt0wpo03z1exdmuo0z5qrzt' />
          </datasources>
          <datasource-dependencies datasource='federated.1q1aqzt0wpo03z1exdmuo0z5qrzt'>
            <column caption='Risk Icon' datatype='string' name='[Calculation_0756469468131331]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [risk_tier]&#13;&#10;    WHEN &quot;High&quot;   THEN &quot;▲ High Risk&quot;&#13;&#10;    WHEN &quot;Medium&quot; THEN &quot;● Medium&quot;&#13;&#10;    WHEN &quot;Low&quot;    THEN &quot;▼ Low&quot;&#13;&#10;    ELSE &quot;Unknown&quot;&#13;&#10;END' />
            </column>
            <column caption='Account Name' datatype='string' name='[account_name]' role='dimension' type='nominal' />
            <column caption='Churn Risk Score' datatype='real' name='[churn_risk_score]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0756469468131331]' derivation='None' name='[none:Calculation_0756469468131331:nk]' pivot='key' type='nominal' />
            <column-instance column='[account_name]' derivation='None' name='[none:account_name:nk]' pivot='key' type='nominal' />
