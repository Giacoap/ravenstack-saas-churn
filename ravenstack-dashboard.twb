      </column>
      <column caption='Is Paying Subscription' datatype='boolean' name='[Calculation_0756469470654474]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT [is_trial_x] AND [mrr_amount] &gt; 0' />
      </column>
      <column caption='Year Month' datatype='datetime' name='[Calculation_0756469470871563]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [start_date])' />
      </column>
      <column caption='Churn Month' datatype='datetime' name='[Calculation_0756469471391756]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [churn_date])' />
      </column>
      <column caption='MRR Activo Mensual' datatype='integer' name='[Calculation_0756469471932429]' role='measure' type='quantitative'>
